class Solution {
  public:
    int largest(vector<int> &arr) {
        // code here
        int n = arr.size();
        int i = 0;
        
        for(int i;i<n;i++){
            for(int j=i+1;j<n;j++){
                if(arr[i] > arr[j]){
                    int temp = arr[i];
                    arr[i] = arr[j];
                    arr[j] = temp;
                }
            }
        }
        return arr[n-1];
    }
};//this is the least optimized method
