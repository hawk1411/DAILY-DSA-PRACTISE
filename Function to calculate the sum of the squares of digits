#include <iostream>
#include <unordered_set>

using namespace std;

// Function to calculate the sum of the squares of digits
int getNext(int n) {
    int sum = 0;
    while (n > 0) {
        int digit = n % 10;
        sum += digit * digit;
        n /= 10;
    }
    return sum;
}

bool isHappy(int n) {
    unordered_set<int> seen;
    
    // Continue until n becomes 1 or we enter a loop
    while (n != 1 && seen.find(n) == seen.end()) {
        seen.insert(n);
        n = getNext(n);
    }
    
    return n == 1;
}

int main() {
    int n;
    
    // Read input
    if (!(cin >> n)) return 0;

    // Check if happy and print the required format
    if (isHappy(n)) {
        cout << n << " is a Happy number" << endl;
    } else {
        cout << n << " is not a Happy number" << endl;
    }

    return 0;
}
