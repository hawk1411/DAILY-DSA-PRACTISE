#Python program that sorts words based on how many vowels they contain.
def count_vowels(word):
    vowels = "aeiouAEIOU"
    count = 0
    for char in word:
        if char in vowels:
            count += 1
    return count
    
def solve():
    try:
        line = input().strip()
        if not line:
            return
        n = int(line)
        
        words = []
        for _ in range(n):
            words.append(input().strip())
            
            
        words.sort(key=count_vowels)
        
        
        for word in words:
            print(word)
            
    except EOFError:
        pass
    
if __name__ == "__main__":
      solve()
      
        
